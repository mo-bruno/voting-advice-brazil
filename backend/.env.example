# Ambiente: dev, staging, prod
APP_ENV=dev
DEBUG=true

# Banco de dados
# Dev: SQLite local
DATABASE_URL=sqlite:///./voting_advice.db
# Prod: Postgres (exemplo Railway)
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db

# Caminho para arquivos de dados estáticos (propostas, teses)
DATA_DIR=../data

# Groq API — obter em https://console.groq.com
GROQ_API_KEY=

# Broker MQTT público HiveMQ
MQTT_BROKER_URL=mqtts://broker.hivemq.com:8883
